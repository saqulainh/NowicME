{
    "model": "public.sitecontent",
    "pk": 9,
    "fields": {
        "section": "faqs",
        "data": [
            {
                "id": "84a3dca0-aa95-4531-a21d-0aef337a9462",
                "q": "How long does it take to build a Software?",
                "a": "We typically build and deliver fully functional, launch-ready within 5 to 10 days, depending on the project scope."
            },
            {
                "id": "326b85a6-d5de-4228-8f70-25faa63f0825",
                "q": "Do you sign NDAs and who owns the source code?",
                "a": "Yes, we sign standard NDAs before discussing any project details. Once the project is delivered, you get 100% ownership of the clean source code and system architecture."
            },
            {
                "id": "144bb342-3648-4078-9fa9-d41b34b390d9",
                "q": "What tech stack do you use for development?",
                "a": "We specialize in modern, scalable tech stacks including Django, React, Clerk authentication, Stripe billing, and high-performance AI integrations."
            },
            {
                "id": "0d1130c3-9fab-4444-b78e-88b4be47f6b0",
                "q": "Do you provide post-launch support?",
                "a": "Yes, we provide full support after deployment to ensure your platform runs smoothly, tracks analytics correctly, and scales flawlessly."
            }
        ],
        "created_at": "2026-07-14T09:00:50.872Z",
        "updated_at": "2026-07-14T09:00:50.872Z"
    }
},
