# ── Core Django ────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_SETTINGS_MODULE=core.settings.dev

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Clerk Auth ─────────────────────────────────────────────────────────────────
# From Clerk Dashboard → API Keys → Advanced
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json
# From Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_your_secret

# JWT validation — get values from Clerk dashboard → API Keys
# Leave empty to skip verification in local dev (not recommended for production)
CLERK_AUDIENCE=
CLERK_ISSUER=https://your-domain.clerk.accounts.dev

# ── Network / Hosts ────────────────────────────────────────────────────────────
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://nowicstudio.in

# ── Proxy Trust ────────────────────────────────────────────────────────────────
# Set to True on Railway/nginx; keeps False locally to avoid IP spoofing risk
TRUST_X_FORWARDED_FOR=False

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
# Gmail: Enable 2FA → Google Account → App Passwords → create for "Mail" → paste here
EMAIL_HOST_PASSWORD=your-16-char-app-password
ADMIN_EMAIL=nowicstdo@gmail.com
DEFAULT_FROM_EMAIL=noreply@nowicstudio.in

# ── Content / Stats ────────────────────────────────────────────────────────────
# Homepage stats: number shown for "Team Members"
TEAM_MEMBERS_COUNT=4

# ── Cloudinary (media uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Redis / Celery ─────────────────────────────────────────────────────────────
# Leave empty to use in-memory cache locally (no Redis needed for dev)
REDIS_URL=redis://localhost:6379/0

# ── Error Tracking ─────────────────────────────────────────────────────────────
# Get from sentry.io → New Project → Django → copy DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
